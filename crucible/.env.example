# --- Database (Postgres via Neon or Supabase) ---
# Use Neon for the current hackathon setup. Runtime should use pooled DATABASE_URL;
# Prisma migrations can use DIRECT_URL when configured.
DATABASE_URL=
DIRECT_URL=
DATABASE_PROVIDER=neon

# --- AI provider (optional; cached outputs are default) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_GATEWAY_API_KEY=
AI_PROVIDER=mock
AI_MODEL=

# --- Gmail (optional, draft-first) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/gmail/callback
GMAIL_DEMO_ACCOUNT=
# Comma-separated allowlist of recipients that live sends are allowed to reach.
# Empty list means no live sending is permitted.
GMAIL_CONTROLLED_RECIPIENTS=
# Optional receiver-inbox Apps Script webhook for the controlled Gmail proof.
GMAIL_REPLY_SIMULATOR_URL=
GMAIL_REPLY_SIMULATOR_SECRET=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Demo / safety flags ---
DEMO_SAFE_MODE=true
USE_CACHED_AI=true
VERCEL_AI_MAX_DURATION_SECONDS=60

# --- Optional tracing / voice ---
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
ELEVENLABS_API_KEY=
