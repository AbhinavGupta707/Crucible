# --- Database (Postgres via Neon or Supabase) ---
# Crucible expects a Postgres-compatible Prisma datasource.
# In demo safe mode the app does not require a live database for UI rendering,
# but the seed script and repository helpers do.
DATABASE_URL=
DATABASE_PROVIDER=neon_or_supabase

# --- AI provider (optional — cached outputs are used when USE_CACHED_AI=true) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_PROVIDER=openai
AI_MODEL=

# --- Gmail (optional, draft-first) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GMAIL_DEMO_ACCOUNT=
# Comma-separated allowlist of recipients that the live send route is allowed
# to deliver to. Empty list means no live sending is permitted.
GMAIL_CONTROLLED_RECIPIENTS=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Demo / safety flags (defaults make the demo resilient) ---
# When DEMO_SAFE_MODE=true, the app uses seeded data and replayed replies and
# refuses to perform live Gmail sends. Keep this on for the hackathon demo.
DEMO_SAFE_MODE=true
# When USE_CACHED_AI=true, structured AI calls return cached fixture outputs
# rather than calling a live provider. Keep this on until the safe-mode demo
# is polished, then flip per-route.
USE_CACHED_AI=true
VERCEL_AI_MAX_DURATION_SECONDS=60

# --- Optional tracing / voice (off by default) ---
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
ELEVENLABS_API_KEY=
